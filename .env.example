# =============================================================================
# Orchestra MCP Platform — Environment Variables
# Domain: orchestra-mcp.dev
#
# Copy this file to .env and fill in all required values:
#   cp .env.example .env
#
# Generate secrets with:
#   openssl rand -hex 32      (for JWT_SECRET, REALTIME_SECRET_KEY_BASE, etc.)
#   openssl rand -hex 64      (for REALTIME_SECRET_KEY_BASE — needs 64 chars)
#
# Generate Supabase keys (ANON_KEY, SERVICE_ROLE_KEY) with:
#   https://supabase.com/docs/guides/self-hosting#api-keys
#   They are JWTs signed with your JWT_SECRET.
# =============================================================================

# ─── PostgreSQL ──────────────────────────────────────────────────────────────

# Password for the postgres superuser. Used by all Supabase services.
POSTGRES_PASSWORD=your-super-secret-postgres-password

# Database name (default: postgres). Most Supabase services expect "postgres".
POSTGRES_DB=postgres

# ─── JWT / Supabase Auth ────────────────────────────────────────────────────

# HMAC secret for signing JWTs. Must be at least 32 characters.
# All Supabase services (GoTrue, PostgREST, Realtime, Storage, Edge) share this.
# Generate: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-at-least-32-characters

# JWT expiry in seconds (default: 3600 = 1 hour)
JWT_EXPIRY=3600

# Supabase anon key — a JWT with role=anon, signed with JWT_SECRET.
# Generate at: https://supabase.com/docs/guides/self-hosting#api-keys
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# Supabase service role key — a JWT with role=service_role, signed with JWT_SECRET.
# WARNING: This key bypasses Row Level Security. Never expose to clients.
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# ─── GoTrue (Auth) Settings ─────────────────────────────────────────────────

# Auto-confirm new users without email verification (true for development)
GOTRUE_MAILER_AUTOCONFIRM=true

# Auto-confirm phone signups without SMS verification
GOTRUE_SMS_AUTOCONFIRM=true

# Disable public signups (set to true to restrict registration)
GOTRUE_DISABLE_SIGNUP=false

# Allowed redirect URIs after OAuth (comma-separated)
GOTRUE_URI_ALLOW_LIST=https://orchestra-mcp.dev/**,https://db.orchestra-mcp.dev/**

# ─── OAuth: Google ───────────────────────────────────────────────────────────

# Enable Google OAuth (true/false)
GOOGLE_AUTH_ENABLED=false

# Google OAuth credentials (from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth: GitHub ───────────────────────────────────────────────────────────

# Enable GitHub OAuth (true/false)
GITHUB_AUTH_ENABLED=false

# GitHub OAuth credentials (from https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── SMTP (Email) ───────────────────────────────────────────────────────────

# SMTP server for sending auth emails (password reset, invites, confirmations).
# Leave blank to disable email sending (requires GOTRUE_MAILER_AUTOCONFIRM=true).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=noreply@orchestra-mcp.dev
SMTP_SENDER_NAME=Orchestra MCP

# ─── Supabase Realtime ──────────────────────────────────────────────────────

# Encryption key for Realtime database connections
REALTIME_DB_ENC_KEY=supabaserealtime

# Secret key base for Realtime Phoenix sessions. Must be at least 64 characters.
# Generate: openssl rand -hex 64
REALTIME_SECRET_KEY_BASE=your-realtime-secret-key-base-must-be-at-least-64-chars-long-generate-with-openssl

# ─── Cloudflare ─────────────────────────────────────────────────────────────

# Cloudflare API token for DNS-01 ACME challenge (wildcard TLS certs).
# Token needs Zone:DNS:Edit permission for orchestra-mcp.dev zone.
# Create at: https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=your-cloudflare-api-token

# ─── Supabase Dashboard ─────────────────────────────────────────────────────

# Studio is secured behind Caddy basic auth + Studio internal auth.
# Username for Studio login.
DASHBOARD_USERNAME=supabase

# Password for Studio login. MUST include at least one letter.
# Generate: openssl rand -hex 12
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated

# Bcrypt hash of DASHBOARD_PASSWORD for Caddy basicauth directive.
# Generate: docker run --rm caddy:2.9-alpine caddy hash-password --plaintext "YOUR_PASSWORD"
DASHBOARD_PASSWORD_HASH=$2a$14$CHANGE_ME_TO_BCRYPT_HASH_OF_YOUR_PASSWORD

# ── ClickHouse (Analytics) ─────────────────────────────────────────────────

# ClickHouse user for the orchestra_analytics database.
CLICKHOUSE_USER=orchestra
CLICKHOUSE_PASSWORD=changeme-clickhouse-password

# ── Supavisor (Connection Pooler) ──────────────────────────────────────────

# Secret key base for Supavisor Phoenix sessions. At least 64 characters.
# Generate: openssl rand -hex 32
SECRET_KEY_BASE=your-secret-key-base-at-least-64-characters-long-generated-with-openssl-rand-hex-32

# Vault encryption key for Supavisor. At least 32 characters.
# Generate: openssl rand -hex 16
VAULT_ENC_KEY=your-vault-enc-key-at-least-32-characters-long
