# ─── 8. MCP Gateway (Streamable HTTP Transport) ─────────────────────────────

mcp.orchestra-mcp.dev {
	import cloudflare-tls
	import security-headers


	# CORS for Claude Desktop and web origins
	@cors_preflight method OPTIONS
	handle @cors_preflight {
		header Access-Control-Allow-Origin "{header.Origin}"
		header Access-Control-Allow-Methods "GET, POST, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, Authorization, Mcp-Session-Id"
		header Access-Control-Expose-Headers "Mcp-Session-Id"
		header Access-Control-Max-Age "86400"
		respond "" 204
	}

	header {
		Access-Control-Allow-Origin "{header.Origin}"
		Access-Control-Allow-Methods "GET, POST, OPTIONS"
		Access-Control-Allow-Headers "Content-Type, Authorization, Mcp-Session-Id"
		Access-Control-Expose-Headers "Mcp-Session-Id"
	}

	# Same gateway binary as api. — unified in apps/gateway/
	# POST /mcp — JSON-RPC requests
	# GET /mcp — SSE stream for server-to-client notifications
	# flush_interval -1 is required for SSE streaming
	reverse_proxy gateway:8080 {
		import proxy-headers
		flush_interval -1
	}

	log {
		output file /var/log/caddy/orchestra-mcp.log {
			roll_size 100mb
			roll_keep 10
		}
		format json
	}
}

# ─── 9. API Gateway ─────────────────────────────────────────────────────────

api.orchestra-mcp.dev {
	import cloudflare-tls
	import security-headers


	encode gzip zstd

	# Tunnel reverse connections — long-lived WebSocket, no buffering
	handle /tunnels/reverse {
		reverse_proxy gateway:8080 {
			import proxy-headers
			flush_interval -1
		}
	}

	# Tunnel WebSocket connections — pattern: /tunnels/{id}/ws
	handle /tunnels/*/ws {
		reverse_proxy gateway:8080 {
			import proxy-headers
			flush_interval -1
		}
	}

	# All other API routes — standard buffered proxy
	handle {
		reverse_proxy gateway:8080 {
			import proxy-headers
		}
	}

	log {
		output file /var/log/caddy/orchestra-api.log {
			roll_size 100mb
			roll_keep 10
		}
		format json
	}
}

# ─── 10. GrowthBook (Feature Flags + A/B Testing) ────────────────────────────
# GrowthBook: port 3000 = Next.js UI, port 3100 = Express API backend.
# APP_ORIGIN = API_HOST = https://flags.orchestra-mcp.dev (same origin).
# Caddy splits: /auth/* and /api/* → Express (3100); rest → Next.js (3000).

flags.orchestra-mcp.dev {
	import cloudflare-tls
	import security-headers

	encode gzip zstd

	# Express backend routes — all non-UI paths go to port 3100
	# Matches: /user, /auth/*, /api/* (except /api/init), /api/v1/*, etc.
	# /api/init → Next.js (public config endpoint, no auth needed)
	handle /api/init {
		reverse_proxy growthbook:3000 {
			import proxy-headers
		}
	}

	# /api/* → Express backend, strip /api prefix so Express sees /user, /organization, etc.
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy growthbook:3100 {
			import proxy-headers
		}
	}

	# /auth/* → Express directly (login, logout, refresh)
	handle /auth/* {
		reverse_proxy growthbook:3100 {
			import proxy-headers
		}
	}

	# Everything else → Next.js UI (pages, static assets)
	handle {
		reverse_proxy growthbook:3000 {
			import proxy-headers
		}
	}

	log {
		output file /var/log/caddy/orchestra-flags.log {
			roll_size 50mb
			roll_keep 5
		}
		format json
	}
}

# ─── 11. GrowthBook SDK API (public alias for external SDK clients) ───────────
# Mobile apps and browsers use this URL for feature flag evaluation.

flags-api.orchestra-mcp.dev {
	import cloudflare-tls

	@cors_preflight method OPTIONS
	handle @cors_preflight {
		header Access-Control-Allow-Origin "*"
		header Access-Control-Allow-Methods "GET, POST, OPTIONS"
		header Access-Control-Allow-Headers "Content-Type, Authorization"
		header Access-Control-Max-Age "86400"
		respond "" 204
	}

	header {
		Access-Control-Allow-Origin "*"
		Access-Control-Allow-Methods "GET, POST, OPTIONS"
		Access-Control-Allow-Headers "Content-Type, Authorization"
		X-Content-Type-Options "nosniff"
		-Server
	}

	reverse_proxy growthbook:3100 {
		import proxy-headers
	}

	log {
		output file /var/log/caddy/orchestra-flags-api.log {
			roll_size 50mb
			roll_keep 5
		}
		format json
	}
}

