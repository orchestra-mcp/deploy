# Orchestra MCP Platform — Production Caddyfile
#
# Domain: orchestra-mcp.dev (all subdomains)
# Requires: caddy built with github.com/caddy-dns/cloudflare (via xcaddy)
# Requires: CF_API_TOKEN environment variable set for Cloudflare DNS-01 challenge
#
# Usage:
#   caddy run --config Caddyfile
#   caddy reload --config Caddyfile
#   caddy validate --config Caddyfile

# ─── Global Options ──────────────────────────────────────────────────────────

{
	# Use Cloudflare DNS-01 for all ACME challenges (wildcard-compatible)
	acme_dns cloudflare {env.CF_API_TOKEN}

	# Trust Cloudflare proxy IPs for real client IP forwarding
	servers {
		trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
	}

	# Structured JSON logs for production log aggregation
	log default {
		output file /var/log/caddy/caddy.log {
			roll_size 100mb
			roll_keep 10
		}
		format json
		level INFO
	}
}

# ─── Reusable Snippets ──────────────────────────────────────────────────────

# TLS via Cloudflare DNS-01 challenge (required for wildcard certs behind Cloudflare proxy)
(cloudflare-tls) {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
}

# Security headers applied to all sites
(security-headers) {
	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-XSS-Protection "0"
		-Server
	}
}

# Standard proxy headers for upstream services
(proxy-headers) {
	header_up X-Real-IP {remote_host}
	header_up X-Forwarded-For {remote_host}
	header_up X-Forwarded-Proto {scheme}
}

# ─── 1. Root Domain — Next.js Profile Platform ──────────────────────────────

orchestra-mcp.dev {
	import cloudflare-tls
	import security-headers


	encode gzip zstd

	# Next.js static assets — immutable cache (content-hashed filenames)
	handle /_next/static/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy host.docker.internal:3000 {
			import proxy-headers
		}
	}

	# All other Next.js routes (SSR, API routes, etc.)
	handle {
		reverse_proxy host.docker.internal:3000 {
			import proxy-headers
		}
	}

	log {
		output file /var/log/caddy/orchestra-root.log {
			roll_size 100mb
			roll_keep 5
		}
		format json
	}
}

# ─── 2. Supabase Studio ─────────────────────────────────────────────────────

db.orchestra-mcp.dev {
	import cloudflare-tls
	import security-headers

	# CORS preflight for all Supabase API routes (PostgREST, GoTrue, Realtime, Storage)
	@cors_preflight {
		method OPTIONS
		path /rest/v1/* /auth/v1/* /realtime/v1/* /storage/v1/* /pg/* /mcp /functions/v1/*
	}
	handle @cors_preflight {
		header Access-Control-Allow-Origin "https://orchestra-mcp.dev"
		header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
		header Access-Control-Allow-Headers "Authorization, apikey, Content-Type, X-Client-Info, X-Supabase-Api-Version, Prefer, Range, Accept-Profile, Content-Profile"
		header Access-Control-Allow-Credentials "true"
		header Access-Control-Max-Age "86400"
		respond "" 204
	}

	# CORS headers on all API responses
	@api_routes {
		path /rest/v1/* /auth/v1/* /realtime/v1/* /storage/v1/* /pg/* /mcp /functions/v1/*
	}
	header @api_routes {
		Access-Control-Allow-Origin "https://orchestra-mcp.dev"
		Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
		Access-Control-Allow-Headers "Authorization, apikey, Content-Type, X-Client-Info, X-Supabase-Api-Version, Prefer, Range, Accept-Profile, Content-Profile"
		Access-Control-Allow-Credentials "true"
		Access-Control-Expose-Headers "Content-Range, X-Total-Count"
	}

	# Allow favicon/manifest without auth (browsers always request these)
	@favicon path /favicon/* /favicon.ico /favicon/manifest.json
	handle @favicon {
		reverse_proxy supabase-studio:3000 {
			import proxy-headers
		}
	}

	# Supabase API routes proxied through Kong (no basic auth — uses apikey header)
	# Studio generates these URLs based on SUPABASE_PUBLIC_URL
	handle /rest/v1/* {
		reverse_proxy supabase-kong:8000 {
			import proxy-headers
		}
	}
	handle /auth/v1/* {
		reverse_proxy supabase-kong:8000 {
			import proxy-headers
		}
	}
	handle /realtime/v1/* {
		reverse_proxy supabase-kong:8000 {
			import proxy-headers
			flush_interval -1
		}
	}
	handle /storage/v1/* {
		reverse_proxy supabase-kong:8000 {
			import proxy-headers
		}
	}
	handle /pg/* {
		reverse_proxy supabase-kong:8000 {
			import proxy-headers
		}
	}

	# Supabase MCP endpoint (routed through Kong — requires service_role apikey)
	handle /mcp {
		reverse_proxy supabase-kong:8000 {
			import proxy-headers
		}
	}

	# All other routes require basic auth (Studio dashboard)
	handle {
		basicauth {
			{env.DASHBOARD_USERNAME} {env.DASHBOARD_PASSWORD_HASH}
		}
		reverse_proxy supabase-studio:3000 {
			import proxy-headers
		}
	}

	log {
		output file /var/log/caddy/orchestra-db.log {
			roll_size 50mb
			roll_keep 5
		}
		format json
	}
}

