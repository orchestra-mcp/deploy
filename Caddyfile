# ─── 5. Supabase Realtime ───────────────────────────────────────────────────

realtime.orchestra-mcp.dev {
	import cloudflare-tls
	import security-headers
	import cloudflare-proxies

	# flush_interval -1 disables response buffering for WebSocket/SSE streaming
	reverse_proxy supabase-realtime:4000 {
		import proxy-headers
		flush_interval -1
	}

	log {
		output file /var/log/caddy/orchestra-realtime.log {
			roll_size 50mb
			roll_keep 5
		}
		format json
	}
}

