# Orchestra MCP Platform — Production Caddyfile
#
# Domain: orchestra-mcp.dev (all subdomains)
# Requires: caddy built with github.com/caddy-dns/cloudflare (via xcaddy)
# Requires: CF_API_TOKEN environment variable set for Cloudflare DNS-01 challenge
#
# Usage:
#   caddy run --config Caddyfile
#   caddy reload --config Caddyfile
#   caddy validate --config Caddyfile

# ─── Global Options ──────────────────────────────────────────────────────────

{
	# Use Cloudflare DNS-01 for all ACME challenges (wildcard-compatible)
	acme_dns cloudflare {env.CF_API_TOKEN}

	# Structured JSON logs for production log aggregation
	log default {
		output file /var/log/caddy/caddy.log {
			roll_size 100mb
			roll_keep 10
		}
		format json
		level INFO
	}
}

# ─── Reusable Snippets ──────────────────────────────────────────────────────

# TLS via Cloudflare DNS-01 challenge (required for wildcard certs behind Cloudflare proxy)
(cloudflare-tls) {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
}

# Security headers applied to all sites
(security-headers) {
	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-XSS-Protection "0"
		-Server
	}
}

# Trust Cloudflare proxy IPs for real client IP forwarding
(cloudflare-proxies) {
	trusted_proxies static \
		173.245.48.0/20 \
		103.21.244.0/22 \
		103.22.200.0/22 \
		103.31.4.0/22 \
		141.101.64.0/18 \
		108.162.192.0/18 \
		190.93.240.0/20 \
		188.114.96.0/20 \
		197.234.240.0/22 \
		198.41.128.0/17 \
		162.158.0.0/15 \
		104.16.0.0/13 \
		104.24.0.0/14 \
		172.64.0.0/13 \
		131.0.72.0/22 \
		2400:cb00::/32 \
		2606:4700::/32 \
		2803:f800::/32 \
		2405:b500::/32 \
		2405:8100::/32 \
		2a06:98c0::/29 \
		2c0f:f248::/32
}

# Standard proxy headers for upstream services
(proxy-headers) {
	header_up X-Real-IP {remote_host}
	header_up X-Forwarded-For {remote_host}
	header_up X-Forwarded-Proto {scheme}
}

# ─── 1. Root Domain — Next.js Profile Platform ──────────────────────────────

orchestra-mcp.dev {
	import cloudflare-tls
	import security-headers
	import cloudflare-proxies

	encode gzip zstd

	# Next.js static assets — immutable cache (content-hashed filenames)
	handle /_next/static/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy nextjs:3000 {
			import proxy-headers
		}
	}

	# All other Next.js routes (SSR, API routes, etc.)
	handle {
		reverse_proxy nextjs:3000 {
			import proxy-headers
		}
	}

	log {
		output file /var/log/caddy/orchestra-root.log {
			roll_size 100mb
			roll_keep 5
		}
		format json
	}
}

# ─── 2. Supabase Studio ─────────────────────────────────────────────────────

db.orchestra-mcp.dev {
	import cloudflare-tls
	import security-headers
	import cloudflare-proxies

	# Studio is protected with basic auth (Supabase dashboard credentials)
	basicauth {
		{env.DASHBOARD_USERNAME} {env.DASHBOARD_PASSWORD_HASH}
	}

	reverse_proxy supabase-studio:3000 {
		import proxy-headers
	}

	log {
		output file /var/log/caddy/orchestra-db.log {
			roll_size 50mb
			roll_keep 5
		}
		format json
	}
}

